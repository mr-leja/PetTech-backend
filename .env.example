# Django
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_NAME=pettech
DB_USER=pettech_user
DB_PASSWORD=pettech_password
DB_HOST=db
DB_PORT=5432

# --- Almacenamiento de imágenes ---
# USE_S3=False  →  archivos en disco local (desarrollo por defecto)
# USE_S3=True   →  sube archivos a Amazon S3 (producción)
USE_S3=False

# Variables requeridas cuando USE_S3=True
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=your-bucket-name
# Dominio personalizado del bucket (opcional, dejar vacío si no se usa CloudFront)
AWS_S3_CUSTOM_DOMAIN=
# Para desarrollo con MinIO (USE_S3=True + endpoint local)
# AWS_S3_ENDPOINT_URL=http://minio:9000

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Admin por defecto
DEFAULT_ADMIN_EMAIL=admin@pettech.com
DEFAULT_ADMIN_PASSWORD=Admin1234!
