# Django
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_NAME=pettech
DB_USER=pettech_user
DB_PASSWORD=pettech_password
DB_HOST=db
DB_PORT=5432

# --- Almacenamiento de imágenes ---
# USE_CLOUDINARY=True   →  sube archivos a Cloudinary (producción)
# USE_CLOUDINARY=False  →  archivos en disco local (desarrollo)
USE_CLOUDINARY=False

# Variables requeridas cuando USE_CLOUDINARY=True
# Obtener desde https://console.cloudinary.com → Settings → API Keys
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Admin por defecto
DEFAULT_ADMIN_EMAIL=admin@pettech.com
DEFAULT_ADMIN_PASSWORD=Admin1234!
